{
  "name": "leaflab-website",
  "type": "module",
  "version": "0.6.0",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "bun run build && wrangler dev",
    "astro": "astro",
    "deploy": "bun run build && wrangler deploy",
    "deploy:production": "cross-env SITE_URL=https://leaflab.sh CLOUDFLARE_ENV=production bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "prepare": "husky",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/cloudflare": "^13.1.1",
    "@astrojs/partytown": "^2.1.5",
    "@astrojs/sitemap": "^3.7.1",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "astro": "^6.0.4",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "jose": "^6.2.1",
    "pino": "^10.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "pretty-quick": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.73.0"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
