---
import SEO from "../components/Seo.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SkipLink from "../components/SkipLink.astro";
import { type JsonLd, site } from "../site-config.ts";

import "../assets/css/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogDesc?: string;
  jsonLd?: JsonLd | JsonLd[];
  robots?: string;
}

const {
  title = site.name,
  description = site.description,
  canonicalPath = Astro.url.pathname,
  ogImage = site.seo.ogImage,
  ogImageAlt = site.seo.ogImageAlt,
  robots = site.seo.robots,
  jsonLd,
} = Astro.props;
const canonical = new URL(canonicalPath, site.url).toString();
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="theme-color" content={site.seo.themeColor} />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      robots={robots}
      jsonLd={jsonLd}
    />
  </head>
  <body class="page">
    <SkipLink />
    <Header />
    <main id="main" class="page__main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
