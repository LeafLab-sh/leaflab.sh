---
import Base from "../layouts/BaseLayout.astro";
import { site } from "../site-config.ts";

const title = `Contact — ${site.name}`;
---

<Base
  title={title}
  description={`Contact ${site.name}`}
  canonicalPath="/contact"
>
  <article class="prose">
    <h1>Contact</h1>

    <p class="lead">Have a project in mind? We'd love to hear about it.</p>

    <p>
      Drop a line with a bit of context: what you're building, where you're
      stuck, or just that you want to explore working together. We'd love to
      hear about it and can put a team together!
    </p>

    <p>Reach us at:</p>

    {
      site.author.email && (
        <p>
          <a href={`mailto:${site.author.email}`}>{site.author.email}</a>
        </p>
      )
    }
  </article>
</Base>
