---
import Base from "../layouts/BaseLayout.astro";
import { site } from "../site-config.ts";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";

const featured = projects.filter((project) => project.featured);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  inLanguage: site.locale,
};
---

<Base
  title={site.name}
  description={site.description}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <article class="prose">
    <h1>Hi, I'm Lea.</h1>
    <p class="lead">
      Software engineer and FIRST Robotics coach in Salt Lake City. I build
      things like game mods, robotics components, and 3D-printed hardware, and
      write about how they come together.
    </p>
  </article>

  <section class="prose">
    <div class="section-head">
      <h2>Featured projects</h2>
      <a class="section-head__link" href="/projects">See all →</a>
    </div>
    <div class="project-grid project-grid--teaser">
      {featured.map((project) => <ProjectCard {...project} />)}
    </div>
  </section>

  <section class="prose">
    <h2>LeafLab</h2>
    <p>
      LeafLab is the consulting side; full-stack web development for small
      businesses and founders who need a technical partner that actually ships. <a
        href="/about">More about that →</a
      >
    </p>
  </section>
</Base>

<style>
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .section-head h2 {
    margin: 0;
  }

  .section-head__link {
    font-size: 14px;
    color: var(--link);
    text-decoration: none;
    white-space: nowrap;
  }

  .section-head__link:hover {
    text-decoration: underline;
  }
</style>
