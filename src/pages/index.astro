---
import Base from "../layouts/BaseLayout.astro";
import { site } from "../site-config.ts";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  inLanguage: site.locale,
};
---

<Base
  title={site.name}
  description={site.description}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <article class="prose">
    <h1>{site.tagline}</h1>
    <p class="lead">{site.description}</p>

    <section class="block">
      <h2>What we do</h2>
      <p>
        Full-stack web development and technical consulting for small businesses
        and founders. That means the whole thing — architecture, implementation,
        infrastructure, and the occasional "wait, why is this broken in
        production" at 11pm. Real ownership, not hand-offs.
      </p>
    </section>

    <section class="block">
      <h2>Who it's for</h2>
      <p>
        You're building something on the web and you need a technical partner
        who can actually execute. You don't want a big agency, a vague estimate,
        or someone who escalates when things get weird. You want people who
        solve the problem and ship the thing.
      </p>
    </section>
  </article>
</Base>
