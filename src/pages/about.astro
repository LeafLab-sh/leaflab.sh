---
import Base from "../layouts/BaseLayout.astro";
import { site } from "../site-config.ts";
import TeamCard from "../components/TeamCard.astro";
import { team } from "../data/team";

const title = `About — ${site.name}`;
---

<Base title={title} description={`About ${site.name}`} canonicalPath="/about">
  <article class="prose">
    <h1>About</h1>

    <p class="lead">
      LeafLab is a network of software developers and technical consultants who
      work with small businesses and early-stage founders building web-based
      products.
    </p>

    <p>
      The name is a little bit of a pun (Lea F... → Leaf) and a little bit of a
      manifesto. The leaf is organic and adaptive. The lab is precise and
      experimental. Together they describe how this practice works: moving
      fluidly across the stack, pulling in the right expertise for each problem,
      and building things that hold up.
    </p>

    <p>
      No big agency overhead, no escalation chains, no "that's not my team's
      scope." Just a tight network of people who actually solve problems and
      ship things.
    </p>
  </article>

  <section class="prose">
    <h2>Team</h2>
    <div class="team-grid">
      {team.map((member) => <TeamCard {...member} />)}
    </div>
  </section>
</Base>
